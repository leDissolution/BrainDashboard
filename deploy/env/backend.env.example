BRAINDASHBOARD_ENVIRONMENT=production
BRAINDASHBOARD_DEBUG=false
BRAINDASHBOARD_HOST=0.0.0.0
BRAINDASHBOARD_PORT=9500
BRAINDASHBOARD_DATABASE_URL=postgresql+asyncpg://braindashboard:change-me@localhost:5432/braindashboard
BRAINDASHBOARD_CORS_ORIGINS='["http://localhost:5175","http://127.0.0.1:5175","http://brainsrv:5175"]'
BRAINDASHBOARD_LLAMA_SWAP_BASE_URL=http://127.0.0.1:9292
LLAMA_SWAP_API_KEY=
BRAINDASHBOARD_GPU_PROFILE_COMMAND=sudo -n /usr/local/sbin/braindashboard-gpu-profile
BRAINDASHBOARD_GPU_PROFILE_TIMEOUT_SECONDS=15
BRAINDASHBOARD_JOB_LOGS_DIR=/var/log/braindashboard/runs
BRAINDASHBOARD_SCHEDULER_ENABLED=true
BRAINDASHBOARD_SCHEDULER_PROCESS_MODE=offprocess
BRAINDASHBOARD_SCHEDULER_TICK_INTERVAL_SECONDS=2
BRAINDASHBOARD_JOB_MAX_ACTIVE_RUNS=1
BRAINDASHBOARD_NATIVE_CANCEL_GRACE_SECONDS=10
BRAINDASHBOARD_HARDWARE_MONITOR_ENABLED=true
BRAINDASHBOARD_HARDWARE_SAMPLE_INTERVAL_SECONDS=1
BRAINDASHBOARD_HARDWARE_BUCKET_SECONDS=60
# Optional: set local electricity price to enable estimated GPU cost fields.
# BRAINDASHBOARD_ELECTRICITY_COST_PER_KWH=0.18
