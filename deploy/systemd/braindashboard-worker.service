[Unit]
Description=BrainDashboard job worker
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=alex
Group=alex
WorkingDirectory=/opt/BrainDashboard
Environment=PYTHONPATH=/opt/BrainDashboard/src
EnvironmentFile=/etc/braindashboard/backend.env
ExecStart=/opt/BrainDashboard/.venv/bin/python -m braindashboard.worker
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
